# Database
DATABASE_URL="postgresql://user:password@localhost:5432/return_zero?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"

# Stream security
STREAM_TOKEN_SECRET="generate-another-strong-secret-for-stream-tokens"
STREAM_TOKEN_TTL_SECONDS=7200

# Allowed domains (comma-separated, no protocol)
ALLOWED_DOMAINS="localhost,localhost:3000,yourdomain.com"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Admin seed (used by prisma db seed)
ADMIN_EMAIL="admin@returnzero.local"
ADMIN_PASSWORD="ChangeMe123!"
